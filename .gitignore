# Git ignore rules for this repository
# This file lists common build, environment, and IDE artifacts to ignore.

## Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
venv/
env/
.venv/
pip-wheel-metadata/
*.egg-info/
dist/
build/
.eggs/

## Node / frontend
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
pnpm-lock.yaml
dist/
build/
.vite/
.parcel-cache/

## Virtual environment and lock files
*.lock

## IDEs and editors
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln
*.swp

## OS files
.DS_Store
Thumbs.db
desktop.ini

## Environment variables
.env
.env.*.local

## Logs and databases
*.log
*.sqlite3
*.db
.pytest_cache/
.cache/
htmlcov/
.coverage
.coverage.*

## Docker
docker-compose.override.yml
Dockerfile.dev

## Other
*.egg
*.egg-info
